# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/weddingsaas?schema=public"
# DIRECT_URL is the same for local dev. In production (Neon/Supabase with pooler) set DIRECT_URL
# to the unpooled connection string used by Prisma Migrate.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/weddingsaas?schema=public"

# Auth.js v5
AUTH_SECRET="change-me-run-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Email provider (magic-link). Free tier: resend.com
RESEND_API_KEY=""
AUTH_EMAIL_FROM="Andrea Morales <noreply@amweddingstudio.example>"
